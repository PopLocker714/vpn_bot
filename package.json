{
    "name": "cat-fly-vpn",
    "version": "1.0.0",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "start": "./dist/server",
        "serve": "bun --hot ./src/index.ts",
        "build": "bun build --bytecode --minify --target=bun --compile ./src/index.ts --outfile=./server",
        "proxy": "clo publish http 4004",
        "proxy:n": "ngrok http 4004 --url live-frog-radically.ngrok-free.app",
        "check:types": "tsc --noEmit",
        "setwh": "bun run scripts/setWebhook.ts",
        "sqlite-memory:generate": "drizzle-kit generate --config=./src/db/sqliteMemory/drizzle.config.ts",
        "sqlite:generate": "drizzle-kit generate --config=./src/db/sqlite/drizzle.config.ts",
        "sqlite:push": "drizzle-kit push --config=./src/db/sqlite/drizzle.config.ts",
        "studio": "bun run drizzle-kit studio --config=./src/db/sqlite/drizzle.config.ts"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "better-sqlite3": "^12.5.0",
        "drizzle-kit": "^0.31.8",
        "localtunnel": "^2.0.2"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "@effect-ak/tg-bot": "^1.2.0",
        "@effect-ak/tg-bot-client": "^1.3.0",
        "@remnawave/backend-contract": "^2.5.6",
        "arkenv": "^0.11.0",
        "arktype": "^2.1.29",
        "drizzle-orm": "^0.45.1"
    }
}
